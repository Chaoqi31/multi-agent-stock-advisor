# =============================================================================
# Required: OpenAI-compatible LLM API
# =============================================================================
OPENAI_COMPATIBLE_API_KEY=your_openai_compatible_api_key
OPENAI_COMPATIBLE_BASE_URL=your_base_url
OPENAI_COMPATIBLE_MODEL=your_model_name

# Summary backend: "api" (default) or "finr1" (local model, GPU host only)
USE_LOCAL_MODEL=api

# =============================================================================
# Optional: debate layer
# =============================================================================
# Number of bull/bear debate rounds (each round = one bull + one bear turn).
MAX_DEBATE_ROUNDS=1

# =============================================================================
# Optional: cross-run advisory memory
# =============================================================================
# Set to "false" to disable memory retrieval/persistence.
ENABLE_MEMORY=true
# Number of similar past situations to retrieve and inject into prompts.
MEMORY_TOP_K=3

# =============================================================================
# Optional: local Qwen-LoRA news scoring (GPU host only; off by default)
# =============================================================================
# USE_LOCAL_NEWS_MODELS=false
# QWEN_BASE_MODEL=/path/to/Qwen
# QWEN_RISK_MODEL=/path/to/qwen_risk_model
# QWEN_SENTIMENT_MODEL=/path/to/qwen_sentiment_model

# =============================================================================
# Optional: override MCP server location (defaults to ../us_stock_mcp_server)
# =============================================================================
# MCP_SERVER_DIR=/abs/path/to/us_stock_mcp_server
